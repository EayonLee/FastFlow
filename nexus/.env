# ============================================================================
# 服务器配置
# ============================================================================

# 服务名称
APP_NAME=FastFlow-Nexus
# 服务端口号
APP_PORT=9090
# 监听地址
APP_HOST=0.0.0.0
# 服务版本号
APP_VERSION=1.1.0


# ============================================================================
# FastFlow Nexus 服务端配置
# ============================================================================

FASTFLOW_API_URL=http://127.0.0.1:8080


# ============================================================================
# 日志配置
# ============================================================================

# 日志级别, "DEBUG", "INFO", "WARNING", "ERROR"
LOG_LEVEL=INFO
# 日志格式类型: text、json
LOG_FORMAT=text
# 日志输出: file、console、both
LOG_OUTPUT=console
# 日志文件路径（为空或 null 则不写入文件）
LOG_FILE_PATH=./nexus/logs/nexus.log
# 控制台彩色输出
LOG_COLORIZE=true
# 日志文件滚动周期,单位"天" - 每天轮转一次
LOG_ROTATION=1
# 日志文件保留时间,单位"天" - 保留7天历史日志
LOG_RETENTION=7
# 单个日志文件最大大小,单位"MB"
LOG_MAX_FILE_SIZE=500


# ============================================================================
# 会话配置
# ============================================================================

# 每个 session 最多保留的消息条数（默认 10 条）
SESSION_HISTORY_MAX_MESSAGES=10
# 会话过期时间（秒）。<=0 表示不过期
SESSION_HISTORY_EXPIRE_SECONDS=3600

# ============================================================================
# 模型运行时配置
# ============================================================================

# 模型流：首个流式事件超时（秒）
MODEL_STREAM_FIRST_EVENT_TIMEOUT_SECONDS=180
# 模型流：空闲超时（秒）
MODEL_STREAM_IDLE_TIMEOUT_SECONDS=150
# 模型流：整轮总超时（秒）
MODEL_STREAM_TOTAL_TIMEOUT_SECONDS=420

# ============================================================================
# 工具调用策略配置（循环保护 / 上限控制）
# ============================================================================

# 单次工具执行超时（秒）
TOOL_EXECUTION_TIMEOUT_SECONDS=15
# 单个用户问题允许执行的工具调用硬上限（防止失控循环）
TOOL_MAX_CALLS_PER_QUESTION=50
# 工具循环检测：warning 阈值（仅告警，不熔断）
TOOL_LOOP_WARNING_THRESHOLD=10
# 工具循环检测：critical 阈值（停止当前工具路径）
TOOL_LOOP_CRITICAL_THRESHOLD=20
# 工具循环检测：global 阈值（停止本轮全部工具调用）
TOOL_LOOP_GLOBAL_THRESHOLD=30
# 工具循环检测窗口：仅观察最近 N 次工具执行历史
TOOL_LOOP_HISTORY_SIZE=30
