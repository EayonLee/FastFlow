{
  "name": "fastflow",
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "postinstall": "wxt prepare",
    "dev": "wxt",
    "dev:chrome": "wxt --browser chrome",
    "watch": "wxt --browser chrome --mode development",
    "build:dev": "wxt build --browser chrome --mode development",
    "build:prod": "wxt build --browser chrome --mode production",
    "zip:prod": "wxt zip --browser chrome --mode production",
    "clean": "rm -rf dist && wxt clean",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@tiptap/core": "^2.12.0",
    "@tiptap/extension-placeholder": "^2.12.0",
    "@tiptap/starter-kit": "^2.12.0",
    "@tiptap/vue-3": "^2.12.0",
    "@vueuse/core": "^12.8.2",
    "axios": "^1.13.4",
    "crypto-js": "^4.2.0",
    "dagre": "^0.8.5",
    "eventsource-parser": "^3.0.6",
    "highlight.js": "^11.11.1",
    "lucide-vue-next": "^0.344.0",
    "markdown-it": "^14.1.1",
    "mermaid": "^11.12.2",
    "svg-pan-zoom": "^3.6.2",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "@wxt-dev/module-vue": "^1.0.3",
    "terser": "^5.46.0",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.5",
    "wxt": "^0.20.18"
  }
}
